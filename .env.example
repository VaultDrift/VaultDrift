# VaultDrift Environment Configuration
# Copy this file to .env and customize as needed

# Server Configuration
VAULTDRIFT_SERVER_HOST=0.0.0.0
VAULTDRIFT_SERVER_PORT=8080
VAULTDRIFT_SERVER_BASE_URL=https://vaultdrift.example.com

# Database
VAULTDRIFT_DATABASE_PATH=/data/vaultdrift.db

# Storage Backend (local or s3)
VAULTDRIFT_STORAGE_BACKEND=local
VAULTDRIFT_STORAGE_LOCAL_PATH=/data/storage

# S3 Configuration (if using S3 backend)
# VAULTDRIFT_STORAGE_S3_ENDPOINT=s3.amazonaws.com
# VAULTDRIFT_STORAGE_S3_BUCKET=my-vaultdrift-bucket
# VAULTDRIFT_STORAGE_S3_REGION=us-east-1
# VAULTDRIFT_STORAGE_S3_ACCESS_KEY=your-access-key
# VAULTDRIFT_STORAGE_S3_SECRET_KEY=your-secret-key
# VAULTDRIFT_STORAGE_S3_USE_PATH_STYLE=false

# Authentication
VAULTDRIFT_AUTH_JWT_SECRET=change-this-to-a-random-secret-key-min-32-chars
VAULTDRIFT_AUTH_ACCESS_TOKEN_TTL=15m
VAULTDRIFT_AUTH_REFRESH_TOKEN_TTL=168h
VAULTDRIFT_AUTH_TOTP_ENABLED=true
VAULTDRIFT_AUTH_MAX_LOGIN_ATTEMPTS=5

# Security
VAULTDRIFT_SECURITY_ALLOW_REGISTRATION=true
VAULTDRIFT_SECURITY_MAX_FILE_SIZE=104857600

# Logging
VAULTDRIFT_LOG_LEVEL=info
VAULTDRIFT_LOG_FORMAT=json

# Features
VAULTDRIFT_FEATURES_SHARING_ENABLED=true
VAULTDRIFT_FEATURES_VERSIONING_ENABLED=true
VAULTDRIFT_FEATURES_TRASH_ENABLED=true
VAULTDRIFT_FEATURES_WEBSOCKET_ENABLED=true
